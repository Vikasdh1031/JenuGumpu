<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/honey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎨 ಗ್ರೇಡಿಂಗ್ ಮಾರ್ಗದರ್ಶಿ"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/honey_brown"
            android:gravity="center"
            android:padding="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Honey Quality Guide"
            android:textSize="14sp"
            android:textColor="@color/text_grey"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- Grade A Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFF9C4">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥇 Grade A — Premium"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/honey_brown"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Color: Light Golden Yellow"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moisture: Below 17%"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price: ₹800 - ₹1200 per kg"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Best for retail and export"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Grade B Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFE0B2">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥈 Grade B — Standard"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/honey_brown"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Color: Amber / Dark Yellow"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moisture: 17% - 20%"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price: ₹500 - ₹800 per kg"
                    android:textSize="14sp"
                    android:textColor="#F57F17"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Good for local markets"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Grade C Card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFCCBC">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥉 Grade C — Processing"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/honey_brown"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Color: Dark Brown"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Moisture: Above 20%"
                    android:textSize="14sp"
                    android:textColor="@color/text_dark"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Price: ₹200 - ₹500 per kg"
                    android:textSize="14sp"
                    android:textColor="#C62828"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️ Needs filtering before sale"
                    android:textSize="13sp"
                    android:textColor="@color/text_grey"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Moisture Test Guide -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@color/honey_brown">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 ತೇವಾಂಶ ಪರೀಕ್ಷೆ (Moisture Test)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Dip a clean stick into honey\n2. Hold it upside down\n3. If honey drips fast → High moisture (Grade C)\n4. If honey drips slowly → Low moisture (Grade A)\n5. No drip in 10 seconds → Perfect Grade A! ✅"
                    android:textSize="13sp"
                    android:textColor="@color/honey_light"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sustainable Harvest Tips -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#E8F5E9">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌿 ಸುಸ್ಥಿರ ಸಂಗ್ರಹ (Sustainable Harvest)"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Never take more than 60% of the hive\n• Always leave honey for the bees to survive\n• Harvest only in dry season\n• Never use fire/smoke excessively\n• Leave the queen bee untouched"
                    android:textSize="13sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>




                <!-- Interactive Moisture Checker -->
                <androidx.cardview.widget.CardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="@color/white">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔬 Interactive Grade Checker"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/honey_brown"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Honey Color"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"
                            android:layout_marginTop="12dp"/>

                        <Spinner
                            android:id="@+id/spinnerColor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Drip Speed"
                            android:textSize="14sp"
                            android:textColor="@color/text_dark"/>

                        <Spinner
                            android:id="@+id/spinnerDrip"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"/>

                        <Button
                            android:id="@+id/btnCheckGrade"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Check My Grade"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/honey_dark"/>

                        <TextView
                            android:id="@+id/tvGradeResult"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/honey_brown"
                            android:gravity="center"
                            android:padding="12dp"/>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>